# Gemini API Key for LLM Processing
GEMINI_API_KEY="your_google_gemini_api_key_here"

# SMTP Configuration for sending lead emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
